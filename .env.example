# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8081

# User uploaded files path
ASSETS_PATH={{ASSETS_PATH}}

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/devops

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379

# JWT Configuration
JWT_SECRET={{JWT_SECRET}}
JWT_EXPIRATION=86400

# Git Repository Storage Path
GIT_REPOS_PATH={{GIT_REPOS_PATH}}

# GitFox Shell Configuration
# Secret token for GitFox Shell internal API authentication
GITFOX_SHELL_SECRET={{GITFOX_SHELL_SECRET}}
# Base URL for GitFox (used for webhooks, LFS, etc.)
GITFOX_BASE_URL={{GITFOX_BASE_URL}}
# GitFox Shell Path
GITFOX_SHELL_PATH={{GITFOX_SHELL_PATH}}

# SSH Server Configuration
SSH_ENABLED=true
SSH_HOST=0.0.0.0
SSH_PORT=22
SSH_HOST_KEY_PATH={{SSH_HOST_KEY_PATH}}
SSH_PUBLIC_HOST={{SSH_PUBLIC_HOST}}
SSH_PUBLIC_PORT=22

# Logging
RUST_LOG=info,actix_web=debug

# Initial Admin User (only used when no admin exists in the database)
# Set all three to auto-create an admin on first startup
INITIAL_ADMIN_USERNAME={{INITIAL_ADMIN_USERNAME}}
INITIAL_ADMIN_EMAIL={{INITIAL_ADMIN_EMAIL}}
INITIAL_ADMIN_PASSWORD={{INITIAL_ADMIN_PASSWORD}}

# ============================================
# OAuth2 Configuration (GitFox as OAuth Client)
# ============================================
# These are for logging into GitFox via external providers

# GitHub OAuth
# Create at: https://github.com/settings/developers
# OAUTH_GITHUB_CLIENT_ID=your_github_client_id
# OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# GitLab OAuth
# Create at: https://gitlab.com/-/profile/applications or your self-hosted instance
# OAUTH_GITLAB_CLIENT_ID=your_gitlab_client_id
# OAUTH_GITLAB_CLIENT_SECRET=your_gitlab_client_secret
# OAUTH_GITLAB_URL=https://gitlab.com (optional, defaults to gitlab.com)

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
# OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Azure AD OAuth (Microsoft)
# Create at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# OAUTH_AZURE_CLIENT_ID=your_azure_client_id
# OAUTH_AZURE_CLIENT_SECRET=your_azure_client_secret
# OAUTH_AZURE_TENANT_ID=your_azure_tenant_id (use 'common' for multi-tenant)

# Bitbucket OAuth
# Create at: https://bitbucket.org/account/settings/app-authorizations/
# OAUTH_BITBUCKET_CLIENT_ID=your_bitbucket_client_id
# OAUTH_BITBUCKET_CLIENT_SECRET=your_bitbucket_client_secret

# ============================================
# Personal Access Token (PAT) Configuration
# ============================================
# Default expiration for PAT in days (0 = no expiration, default: 365)
PAT_DEFAULT_EXPIRATION_DAYS=365
# Maximum expiration for PAT in days (0 = no limit, default: 0)
PAT_MAX_EXPIRATION_DAYS=0

# ============================================
# Email Configuration
# ============================================
SMTP_ENABLED={{SMTP_ENABLED}}
SMTP_HOST={{SMTP_HOST}}
SMTP_PORT={{SMTP_PORT}}
SMTP_USERNAME={{SMTP_USERNAME}}
SMTP_PASSWORD={{SMTP_PASSWORD}}
SMTP_FROM_EMAIL={{SMTP_FROM_EMAIL}}
SMTP_FROM_NAME={{SMTP_FROM_NAME}}
SMTP_USE_TLS={{SMTP_USE_TLS}}
SMTP_USE_SSL={{SMTP_USE_SSL}}


# ============================================
# WebAuthn/Passkey Configuration (Two-Factor Authentication)
# ============================================
# IMPORTANT: WEBAUTHN_ORIGIN must match the URL where users access the frontend!
# For localhost development:

WEBAUTHN_RP_NAME=GitFox
WEBAUTHN_RP_ID={{WEBAUTHN_RP_ID}}
# WEBAUTHN_ORIGIN=http://192.168.3.104:3000

# ============================================  
# WebIde Configuration
# ============================================
# NOTE: WebIDE must be enabled in system_configs database table:
#   INSERT INTO system_configs (key, value) VALUES ('webide_enabled', 'true');
# Or enable it through Admin Settings UI after first startup

# Fixed client ID for WebIDE OAuth application (default: gitfox-webide)
WEBIDE_CLIENT_ID=gitfox-webide

# OAuth redirect URI path for WebIDE (default: /-/ide/oauth/callback)
WEBIDE_REDIRECT_URI_PATH=/-/ide/oauth/callback