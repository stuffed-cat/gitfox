# ============================================
# Server Configuration
# ============================================
# 后端支持两种监听方式：
# - tcp: 使用 TCP 端口（默认，适合大多数部署）
# - unix_socket: 使用 Unix Socket（推荐用于 Nginx 反向代理，性能更好）

SERVER_CONNECTION_TYPE={{SERVER_CONNECTION_TYPE}}

# TCP 模式配置 (SERVER_CONNECTION_TYPE=tcp)
SERVER_HOST={{SERVER_HOST}}
SERVER_PORT={{SERVER_PORT}}

# Unix Socket 模式配置 (SERVER_CONNECTION_TYPE=unix_socket)
# 使用 Unix Socket 时，Nginx 配置示例：
#   upstream gitfox {
#     server unix:/var/run/gitfox/gitfox.sock;
#   }
SERVER_SOCKET_PATH={{SERVER_SOCKET_PATH}}

# ============================================
# File Upload Configuration
# ============================================
# Maximum file upload size in bytes (default: 1GB)
# Git push operations may require larger limits for repositories with large files
# 推荐值：
# - 小型团队：524288000 (500MB)
# - 中型团队：1073741824 (1GB)
# - 大型团队/企业：2147483648 (2GB) or higher
MAX_UPLOAD_SIZE={{MAX_UPLOAD_SIZE}}

# User uploaded files storage path (avatars, attachments, etc.)
# 确保此目录有足够的磁盘空间和适当的权限
ASSETS_PATH={{ASSETS_PATH}}

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database
# 生产环境建议：
# - 使用强密码
# - 启用 SSL 连接：?sslmode=require
# - 配置连接池大小：?max_connections=20
DATABASE_URL=postgres://postgres:password@localhost:5432/devops

# ============================================
# Redis Configuration
# ============================================
# Redis connection string for caching and session storage
# Format: redis://[password@]host:port[/db]
# 示例：
# - 本地无密码：redis://127.0.0.1:6379
# - 有密码：redis://:mypassword@127.0.0.1:6379
# - 指定数据库：redis://127.0.0.1:6379/1
REDIS_URL=redis://127.0.0.1:6379

# ============================================
# JWT Authentication Configuration
# ============================================
# JWT secret key for signing tokens
# 生产环境必须修改为强随机字符串！建议至少 32 字符
# 生成方法：openssl rand -base64 32
JWT_SECRET={{JWT_SECRET}}

# JWT token expiration time in seconds (default: 86400 = 24 hours)
# 推荐值：
# - 开发环境：86400 (24小时)
# - 生产环境：3600 (1小时) 或 7200 (2小时)
JWT_EXPIRATION=86400

# ============================================
# Git Repository Storage
# ============================================
# Git 仓库存储路径（绝对路径）
# 所有 Git 仓库将存储在此目录下，按 namespace/project.git 结构组织
# 确保此目录：
# - 有足够的磁盘空间（建议至少 100GB）
# - 使用高性能存储（SSD 推荐）
# - 有适当的权限（运行用户可读写）
# - 定期备份
GIT_REPOS_PATH={{GIT_REPOS_PATH}}

# ============================================
# GitFox Shell Internal API Configuration
# ============================================
# Secret token for GitFox Shell internal API authentication
# 用于 gitfox-shell 与主应用之间的内部 API 认证
# 生产环境必须修改为强随机字符串！
# 生成方法：openssl rand -base64 32
GITFOX_SHELL_SECRET={{GITFOX_SHELL_SECRET}}

# Base URL for GitFox instance (used for webhooks, LFS, clone URLs, etc.)
# 格式：http(s)://domain[:port]
# 示例：
# - 开发环境：http://localhost:8080
# - 生产环境：https://git.example.com
GITFOX_BASE_URL={{GITFOX_BASE_URL}}

# Internal API URL (gitfox-shell 用于连接主应用)
# 通常使用 127.0.0.1 或 ::1 本地连接，端口与 SERVER_PORT 一致
# 如果未设置，将自动使用 http://127.0.0.1:<SERVER_PORT>
# GITFOX_INTERNAL_API_URL=http://127.0.0.1:8080

# GitFox Shell binary path (for authorized_keys command)
# 开发环境示例（相对路径）
GITFOX_SHELL_PATH={{GITFOX_SHELL_PATH}}
# 生产环境示例（绝对路径）
# GITFOX_SHELL_PATH=/usr/local/bin/gitfox-shell

# ============================================
# gRPC Service Configuration
# ============================================
# Enable gRPC Auth service (for gitfox-shell and gitfox-workhorse)
# gRPC 提供高性能的内部服务通信
GRPC_ENABLED=true

# gRPC Auth service listen address
# IPv4: 127.0.0.1:50051 (仅本地) 或 0.0.0.0:50051 (所有接口)
# IPv6: [::1]:50051 (仅本地) 或 [::]:50051 (所有接口)
# 推荐使用 localhost 地址以提高安全性
GRPC_ADDRESS=[::1]:50051

# GitLayer gRPC service address (optional, for Git operations via RPC)
# 如果启用 GitLayer，配置其 gRPC 地址
# 格式：http://[host]:port 或 https://[host]:port
# GITLAYER_ADDRESS=http://[::1]:50052

# ============================================
# SSH Clone URL Configuration
# ============================================
# Enable SSH clone URLs in the frontend
SSH_ENABLED=true

# Public hostname for SSH clone URLs (e.g., git.example.com)
SSH_PUBLIC_HOST={{SSH_PUBLIC_HOST}}

# Public port for SSH clone URLs (default: 2222)
# Use the port where gitfox-shell SSH server is listening
SSH_PUBLIC_PORT={{SSH_PUBLIC_PORT}}

# ============================================
# Logging Configuration
# ============================================
# Log level: trace, debug, info, warn, error
RUST_LOG=info,actix_web=debug

# Enable detailed SQL logging (warning: verbose)
# RUST_LOG=sqlx=debug,info

# ============================================
# Initial Admin User Configuration
# ============================================
# These settings are ONLY used when no admin user exists in the database
# After the first admin is created, these settings are ignored
# 首次启动时自动创建管理员账户，之后忽略这些配置

# Admin username (3-39 characters, alphanumeric, dash, underscore)
INITIAL_ADMIN_USERNAME={{INITIAL_ADMIN_USERNAME}}

# Admin email address (must be valid email format)
INITIAL_ADMIN_EMAIL={{INITIAL_ADMIN_EMAIL}}

# Admin password (minimum 8 characters recommended)
INITIAL_ADMIN_PASSWORD={{INITIAL_ADMIN_PASSWORD}}

# ============================================
# OAuth2 Configuration (GitFox as OAuth Client)
# ============================================
# These settings enable users to log into GitFox using external OAuth providers
# 用户可以使用外部账号登录 GitFox

# ----------------------
# GitHub OAuth
# ----------------------
# Register at: https://github.com/settings/developers
# Authorization callback URL: <GITFOX_BASE_URL>/oauth/callback/github
# Example: http://localhost:8080/oauth/callback/github
# OAUTH_GITHUB_CLIENT_ID=your_github_client_id
# OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# ----------------------
# GitLab OAuth
# ----------------------
# Register at: https://gitlab.com/-/profile/applications (or your self-hosted instance)
# Authorization callback URL: <GITFOX_BASE_URL>/oauth/callback/gitlab
# OAUTH_GITLAB_CLIENT_ID=your_gitlab_client_id
# OAUTH_GITLAB_CLIENT_SECRET=your_gitlab_client_secret
# Custom GitLab instance URL (optional, defaults to gitlab.com):
# OAUTH_GITLAB_URL=https://gitlab.example.com

# ----------------------
# Google OAuth
# ----------------------
# Register at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <GITFOX_BASE_URL>/oauth/callback/google
# OAUTH_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# ----------------------
# Azure AD OAuth (Microsoft)
# ----------------------
# Register at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI: <GITFOX_BASE_URL>/oauth/callback/azure_ad
# OAUTH_AZURE_CLIENT_ID=your_azure_client_id
# OAUTH_AZURE_CLIENT_SECRET=your_azure_client_secret
# Tenant ID (use 'common' for multi-tenant, 'organizations' for work/school accounts only):
# OAUTH_AZURE_TENANT_ID=common

# ----------------------
# Bitbucket OAuth
# ----------------------
# Register at: https://bitbucket.org/account/settings/app-authorizations/
# Callback URL: <GITFOX_BASE_URL>/oauth/callback/bitbucket
# OAUTH_BITBUCKET_CLIENT_ID=your_bitbucket_client_id
# OAUTH_BITBUCKET_CLIENT_SECRET=your_bitbucket_client_secret

# ============================================
# Personal Access Token (PAT) Configuration
# ============================================
# Default expiration for new PAT in days
# 0 = no expiration (not recommended for security)
# 推荐值：90 (三个月) 或 365 (一年)
PAT_DEFAULT_EXPIRATION_DAYS=365

# Maximum expiration for PAT in days
# 0 = no limit, users can create tokens with any expiration
# 推荐在企业环境中设置最大限制（如 730 = 2年）
PAT_MAX_EXPIRATION_DAYS=0

# ============================================
# Email (SMTP) Configuration
# ============================================
# Enable email sending (set false to disable all email features)
SMTP_ENABLED={{SMTP_ENABLED}}

# SMTP server hostname or IP address
SMTP_HOST={{SMTP_HOST}}

# SMTP server port
# Common ports: 25 (plain), 587 (STARTTLS), 465 (SSL/TLS)
SMTP_PORT={{SMTP_PORT}}

# SMTP authentication credentials
SMTP_USERNAME={{SMTP_USERNAME}}
SMTP_PASSWORD={{SMTP_PASSWORD}}

# Email sender information (appears in "From" field)
SMTP_FROM_EMAIL={{SMTP_FROM_EMAIL}}
SMTP_FROM_NAME={{SMTP_FROM_NAME}}

# Enable STARTTLS encryption (recommended for port 587)
SMTP_USE_TLS={{SMTP_USE_TLS}}

# Enable implicit SSL/TLS encryption (for port 465)
SMTP_USE_SSL={{SMTP_USE_SSL}}

# Popular SMTP provider examples:
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USERNAME=your-email@gmail.com
#   SMTP_PASSWORD=app-specific-password
#
# Outlook/Office 365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USERNAME=apikey
#   SMTP_PASSWORD=<your-sendgrid-api-key>
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USE_TLS=true


# ============================================
# WebAuthn/Passkey Configuration (Two-Factor Authentication)
# ============================================
# WebAuthn 用于生物认证（指纹、Face ID）和硬件安全密钥（YubiKey）

# IMPORTANT: WEBAUTHN_ORIGIN must EXACTLY match the URL users access!
# 必须与用户访问的 URL 完全匹配（包括协议和端口）

# Relying Party (RP) display name (shown to users during authentication)
WEBAUTHN_RP_NAME=GitFox

# Relying Party ID (domain without protocol/port)
# Must be the domain name users access (e.g., "example.com", "localhost")
# For development:
#   - localhost -> WEBAUTHN_RP_ID=localhost
#   - 192.168.x.x -> WEBAUTHN_RP_ID=192.168.x.x (some browsers don't support IP addresses)
WEBAUTHN_RP_ID={{WEBAUTHN_RP_ID}}

# Origin URL (MUST include protocol and match user's browser URL EXACTLY)
# Development examples:
#   WEBAUTHN_ORIGIN=http://localhost:3000
#   WEBAUTHN_ORIGIN=http://192.168.3.104:3000
# Production example:
#   WEBAUTHN_ORIGIN=https://git.example.com
# WEBAUTHN_ORIGIN=http://192.168.3.104:3000

# ============================================  
# WebIDE Configuration
# ============================================
# GitFox 内置基于 Web 的代码编辑器 (IDE)
# NOTE: WebIDE 需要在数据库 system_configs 表中启用：
#   INSERT INTO system_configs (key, value) VALUES ('webide_enabled', 'true');
# 或者在首次启动后通过管理员设置界面启用

# Fixed client ID for WebIDE OAuth application (do not change)
# WebIDE OAuth 应用的固定客户端 ID（不要修改）
WEBIDE_CLIENT_ID=gitfox-webide

# OAuth redirect URI path for WebIDE callback
# WebIDE OAuth 回调路径（通常不需要修改）
WEBIDE_REDIRECT_URI_PATH=/-/ide/oauth/callback