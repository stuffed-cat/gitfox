{
  "name": "@gitfox/web-ide",
  "version": "1.0.0",
  "description": "GitFox WebIDE - VS Code based Web IDE with GitFox integration",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:packages && vite build && npm run patch:vscode && npm run copy:extensions && cd extensions/gitfox-provider && npm run build && cd ../..",
    "build:packages": "npm run build --workspace=@gitfox/api-client --workspace=@gitfox/oauth-client --workspace=@gitfox/webide-fs --workspace=@gitfox/webide",
    "preview": "vite preview",
    "build:vscode": "node scripts/build-vscode.js",
    "copy:extensions": "node -e \"require('fs').cpSync('extensions', 'dist/extensions', {recursive: true})\"",
    "postinstall": "node scripts/postinstall.js",
    "patch:vscode": "node scripts/postinstall.js --patch-only",
    "postbuild": "npm run patch:vscode"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "tar": "^7.0.0"
  }
}
