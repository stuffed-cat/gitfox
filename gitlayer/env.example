# ============================================
# GitLayer Configuration
# ============================================
# GitLayer 是类似 GitLab Gitaly 的 Git 操作 RPC 服务

# ============================================
# gRPC Server
# ============================================
# gRPC 监听地址
GITLAYER_LISTEN_ADDR=0.0.0.0:50052

# ============================================
# Repository Storage
# ============================================
# Git 仓库存储路径（与主应用的 GIT_REPOS_PATH 一致）
GITLAYER_STORAGE_PATH=/var/opt/gitfox/repos
# 或者使用共享变量：
# GIT_REPOS_PATH=/var/opt/gitfox/repos

# ============================================
# Git Binary
# ============================================
# Git 二进制路径（默认使用 PATH 中的 git）
# GITLAYER_GIT_BIN=/usr/bin/git

# ============================================
# Performance
# ============================================
# 每个仓库的最大并发操作数
GITLAYER_MAX_CONCURRENT_OPS=10

# 启用仓库缓存
GITLAYER_ENABLE_CACHE=true

# 缓存 TTL（秒）
GITLAYER_CACHE_TTL=60
