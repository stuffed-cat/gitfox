# ============================================
# GitLayer Configuration
# ============================================
# GitLayer 是类似 GitLab Gitaly 的 Git 操作 RPC 服务
# 负责处理所有 Git 仓库操作，包括读写、克隆、推送等
# 此文件由 gitfox reconfigure 自动生成，请勿手动编辑

# ============================================
# gRPC Server
# ============================================
# gRPC 监听地址和端口
# 使用 0.0.0.0 监听所有接口，使用 127.0.0.1 仅监听本地
# IPv6: [::]:50052 或 [::1]:50052
GITLAYER_LISTEN_ADDR={{GITLAYER_LISTEN_ADDR}}

# ============================================
# Repository Storage
# ============================================
# Git 仓库存储路径（绝对路径）
# 所有仓库将存储在此目录下，按 namespace/project.git 结构组织
# 确保此目录有足够的磁盘空间和适当的权限
GITLAYER_STORAGE_PATH={{GIT_REPOS_PATH}}

# ============================================
# Git Binary Configuration
# ============================================
# Git 二进制文件路径（默认使用 PATH 中的 git）
# 可以指定特定版本的 git，确保版本 >= 2.0
GITLAYER_GIT_BIN={{GITLAYER_GIT_BIN}}
# 示例：使用特定路径
# GITLAYER_GIT_BIN=/usr/bin/git
# GITLAYER_GIT_BIN=/opt/git/bin/git

# ============================================
# Performance Tuning
# ============================================
# 每个仓库的最大并发操作数（默认：10）
# 增加此值可以提高并发性能，但会消耗更多内存
# 建议根据 CPU 核心数和可用内存调整
GITLAYER_MAX_CONCURRENT_OPS={{GITLAYER_MAX_CONCURRENT_OPS}}

# 启用仓库元数据缓存（默认：true）
# 缓存仓库引用、提交信息等，可以显著提升性能
GITLAYER_ENABLE_CACHE={{GITLAYER_ENABLE_CACHE}}

# 缓存有效期（秒，默认：60）
# 较长的 TTL 可以提升性能，但可能导致数据不够实时
GITLAYER_CACHE_TTL={{GITLAYER_CACHE_TTL}}

# ============================================
# Logging
# ============================================
# 日志级别: trace, debug, info, warn, error
RUST_LOG={{RUST_LOG}}

# 启用调试模式（生产环境请设置为 false）
# DEBUG=false
