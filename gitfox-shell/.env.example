# ============================================
# GitFox Shell Configuration
# ============================================
# gitfox-shell 是独立的 SSH 服务器，类似 gitlab-shell
# 不需要依赖系统 sshd
# 此文件由 gitfox reconfigure 自动生成，请勿手动编辑

# ============================================
# SSH Server Configuration
# ============================================
# SSH 服务监听地址和端口
# 格式: IP:PORT
# - 0.0.0.0:2222 - 所有接口，端口 2222（推荐用于生产环境）
# - 127.0.0.1:2222 - 仅本地访问
# - [::]:2222 - 所有接口 (IPv6)
# 
# 注意：不建议使用特权端口 22，除非以 root 运行
# 生产环境推荐使用 2222 或其他非特权端口
SSH_LISTEN_ADDR={{SSH_LISTEN_ADDR}}

# Host Key 文件路径
# 如果文件不存在，将自动生成 Ed25519 密钥对
# 生产环境建议提前生成并妥善保管私钥：
#   ssh-keygen -t ed25519 -f /etc/gitfox/ssh_host_ed25519_key -N ""
SSH_HOST_KEY_PATH={{SSH_HOST_KEY_PATH}}

# ============================================
# gRPC Configuration (Required)
# ============================================
# gitfox-shell 通过 gRPC 与主应用和 GitLayer 通信

# Auth gRPC 服务地址（主应用提供的认证服务）
# 用于验证 SSH 密钥和检查仓库访问权限
# 格式: http://[host]:port 或 https://[host]:port
# IPv4 示例: http://127.0.0.1:50051
# IPv6 示例: http://[::1]:50051
# 注意：必须与主应用的 GRPC_ADDRESS 配置一致
AUTH_GRPC_ADDRESS={{AUTH_GRPC_ADDRESS}}

# GitLayer gRPC 服务地址（Git 操作服务）
# 所有 Git clone/fetch/push 操作都通过 GitLayer 执行
# gitfox-shell 不直接访问仓库目录
# 格式与 AUTH_GRPC_ADDRESS 相同
# 注意：必须与 GitLayer 的 GITLAYER_LISTEN_ADDR 配置一致
GITLAYER_ADDRESS={{GITLAYER_ADDRESS}}

# 内部 API 认证密钥
# 用于 gitfox-shell 与主应用之间的 API 认证
# 必须与主应用的 GITFOX_SHELL_SECRET 保持一致
# 生产环境必须使用强随机字符串！
# 生成方法：openssl rand -base64 32
GITFOX_API_SECRET={{GITFOX_SHELL_SECRET}}

# ============================================
# Logging Configuration
# ============================================
# 日志级别控制输出的详细程度
# 可选值: trace, debug, info, warn, error
# 推荐设置：
# - 开发环境: debug
# - 生产环境: info 或 warn
# 
# 高级配置（可以为不同模块设置不同级别）：
# RUST_LOG=info,gitfox_shell=debug,russh=warn
RUST_LOG={{RUST_LOG}}

# 启用调试日志（生产环境请设置为 false）
# 启用后会输出详细的调试信息，包括：
# - SSH 连接详情
# - gRPC 请求/响应
# - Git 命令执行
GITFOX_DEBUG={{GITFOX_DEBUG}}
