# ============================================
# GitFox Shell Configuration
# ============================================

# ============================================
# API Authentication (Legacy HTTP Mode)
# ============================================
# GitFox API URL (用于 HTTP API 认证模式)
GITFOX_API_URL=http://localhost:8080

# API Secret (内部通信认证密钥，与 GITFOX_SHELL_SECRET 一致)
GITFOX_API_SECRET=your-secret-token-here

# API 请求超时时间（秒）
GITFOX_API_TIMEOUT=30

# ============================================
# gRPC Authentication (Recommended)
# ============================================
# 使用 gRPC 进行权限认证（推荐，类似 GitLab 架构）
GITFOX_USE_GRPC_AUTH=true

# Auth gRPC 服务地址（主应用提供）
AUTH_GRPC_ADDRESS=http://[::1]:50051

# ============================================
# GitLayer Configuration
# ============================================
# 使用 GitLayer 处理 Git 操作
GITFOX_USE_GITLAYER=true

# GitLayer gRPC 服务地址
GITLAYER_ADDRESS=http://[::1]:50052

# ============================================
# Repository Storage
# ============================================
# Git 仓库存储路径
GITFOX_REPOS_PATH=/var/opt/gitfox/repos

# ============================================
# Git Binaries (Optional)
# ============================================
# git-upload-pack 路径（默认使用 PATH 中的）
# GITFOX_GIT_UPLOAD_PACK=/usr/bin/git-upload-pack

# git-receive-pack 路径
# GITFOX_GIT_RECEIVE_PACK=/usr/bin/git-receive-pack

# ============================================
# Debug
# ============================================
# 启用调试日志（生产环境请关闭）
GITFOX_DEBUG=false
